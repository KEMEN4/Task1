   "source": [
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# =========================================================\n",
    "# 11) COMPLETE EXPORTS (all derived CSV files)\n",
    "# =========================================================\n",
    "OUTDIR = Path(\"exports_task1\")\n",
    "OUTDIR.mkdir(exist_ok=True)\n",
    "\n",
    "# ---------- (1) FULL HOURLY DATA ----------\n",
    "# contains T_out, HDH/CDH, q_heating/q_cooling, COP/EER, P_elec, etc.\n",
    "hourly_full = OUTDIR / \"01_hourly_FULL_all_columns.csv\"\n",
    "df.reset_index().to_csv(hourly_full, index=False)\n",
    "\n",
    "# ---------- (2) ESSENTIAL HOURLY (Task1) ----------\n",
    "# minimum columns required for your supervisor\n",
    "essential_cols = [\n",
    "    \"timestamp\", \"T_out_C\",\n",
    "    \"HDH_degC_h\", \"CDH_degC_h\",\n",
    "    \"q_heating_kW\", \"q_cooling_kW\",\n",
    "    \"COP_t\", \"EER_t\",\n",
    "    \"P_heat_elec_kW\", \"P_cool_elec_kW\", \"P_HP_total_kW\"\n",
    "]\n",
    "hourly_task1 = OUTDIR / \"02_hourly_TASK1_essential.csv\"\n",
    "df.reset_index()[essential_cols].to_csv(hourly_task1, index=False)\n",
    "\n",
    "# ---------- (3) FULL DAILY PROFILES ----------\n",
    "# IMPORTANT: in your code you reuse 'daily' for averages!\n",
    "# Here we rebuild a complete daily dataset:\n",
    "# daily averages + HDD/CDD + daily energies\n",
    "daily_mean = df.resample(\"D\").mean(numeric_only=True)\n",
    "\n",
    "daily_energy = df.resample(\"D\").sum(numeric_only=True)[\n",
    "    [\"q_heating_kW\", \"q_cooling_kW\", \"P_heat_elec_kW\", \"P_cool_elec_kW\", \"P_HP_total_kW\",\n",
    "     \"HDH_degC_h\", \"CDH_degC_h\"]\n",
    "].rename(columns={\n",
    "    \"q_heating_kW\": \"Q_heating_kWh_day\",\n",
    "    \"q_cooling_kW\": \"Q_cooling_kWh_day\",\n",
    "    \"P_heat_elec_kW\": \"E_heat_elec_kWh_day\",\n",
    "    \"P_cool_elec_kW\": \"E_cool_elec_kWh_day\",\n",
    "    \"P_HP_total_kW\": \"E_HP_total_kWh_day\",\n",
    "})\n",
    "\n",
    "daily_out = pd.DataFrame(index=daily_mean.index)\n",
    "daily_out[\"Tmean_C\"] = df[\"T_out_C\"].resample(\"D\").mean()\n",
    "daily_out[\"Tmin_C\"]  = df[\"T_out_C\"].resample(\"D\").min()\n",
    "daily_out[\"Tmax_C\"]  = df[\"T_out_C\"].resample(\"D\").max()\n",
    "\n",
    "daily_out[\"HDD_degC_day\"] = (daily_energy[\"HDH_degC_h\"] / 24.0)\n",
    "daily_out[\"CDD_degC_day\"] = (daily_energy[\"CDH_degC_h\"] / 24.0)\n",
    "\n",
    "daily_out[\"is_heating_day\"] = daily_out[\"HDD_degC_day\"] > 0\n",
    "daily_out[\"is_cooling_day\"] = daily_out[\"CDD_degC_day\"] > 0\n",
    "\n",
    "# Join daily energy values\n",
    "daily_out = daily_out.join(daily_energy[[\n",
    "    \"Q_heating_kWh_day\", \"Q_cooling_kWh_day\",\n",
    "    \"E_heat_elec_kWh_day\", \"E_cool_elec_kWh_day\", \"E_HP_total_kWh_day\"\n",
    "]])\n",
    "\n",
    "# Join daily performance averages\n",
    "daily_out[\"COP_mean_day\"] = daily_mean[\"COP_t\"]\n",
    "daily_out[\"EER_mean_day\"] = daily_mean[\"EER_t\"]\n",
    "\n",
    "daily_csv = OUTDIR / \"03_daily_profiles_HDD_CDD_energy.csv\"\n",
    "daily_out.reset_index().rename(columns={\"timestamp\": \"date\"}).to_csv(daily_csv, index=False)\n",
    "\n",
    "# ---------- (4) MONTHLY TOTALS ----------\n",
    "monthly = pd.DataFrame(index=daily_out.resample(\"M\").sum(numeric_only=True).index)\n",
    "monthly[\"HDD_degC_day_month\"] = daily_out[\"HDD_degC_day\"].resample(\"M\").sum()\n",
    "monthly[\"CDD_degC_day_month\"] = daily_out[\"CDD_degC_day\"].resample(\"M\").sum()\n",
    "\n",
    "monthly[\"Q_heating_kWh_month\"] = daily_out[\"Q_heating_kWh_day\"].resample(\"M\").sum()\n",
    "monthly[\"Q_cooling_kWh_month\"] = daily_out[\"Q_cooling_kWh_day\"].resample(\"M\").sum()\n",
    "\n",
    "monthly[\"E_HP_total_kWh_month\"] = daily_out[\"E_HP_total_kWh_day\"].resample(\"M\").sum()\n",
    "monthly[\"E_heat_elec_kWh_month\"] = daily_out[\"E_heat_elec_kWh_day\"].resample(\"M\").sum()\n",
    "monthly[\"E_cool_elec_kWh_month\"] = daily_out[\"E_cool_elec_kWh_day\"].resample(\"M\").sum()\n",
    "\n",
    "monthly[\"COP_mean_month\"] = daily_mean[\"COP_t\"].resample(\"M\").mean()\n",
    "monthly[\"EER_mean_month\"] = daily_mean[\"EER_t\"].resample(\"M\").mean()\n",
    "\n",
    "monthly_csv = OUTDIR / \"04_monthly_totals.csv\"\n",
    "monthly.reset_index().rename(columns={\"timestamp\": \"month\"}).to_csv(monthly_csv, index=False)\n",
    "\n",
    "# ---------- (5) ANNUAL SUMMARY (totals + peaks) ----------\n",
    "summary = {\n",
    "    \"UA_W_per_K\": UA,\n",
    "    \"V_m3\": V,\n",
    "    \"ACH_1_per_h\": ACH,\n",
    "    \"rho_kg_per_m3\": rho,\n",
    "    \"Cp_J_per_kgK\": Cp,\n",
    "    \"m_dot_kg_s\": float(m_dot),\n",
    "    \"mCp_W_per_K\": float(mCp),\n",
    "    \"BLC_W_per_K\": float(BLC),\n",
    "    \"q_g_W\": float(q_g),\n",
    "    \"Tin_heat_C\": float(Tin_heat),\n",
    "    \"Tin_cool_C\": float(Tin_cool),\n",
    "    \"Tb_heat_C\": float(Tb_heat),\n",
    "    \"Tb_cool_C\": float(Tb_cool),\n",
    "    \"NH_days\": int(daily_out[\"is_heating_day\"].sum()),\n",
    "    \"NC_days\": int(daily_out[\"is_cooling_day\"].sum()),\n",
    "    \"HDD_total_degC_day\": float(daily_out[\"HDD_degC_day\"].sum()),\n",
    "    \"CDD_total_degC_day\": float(daily_out[\"CDD_degC_day\"].sum()),\n",
    "    \"Q_heating_kWh_year\": float(daily_out[\"Q_heating_kWh_day\"].sum()),\n",
    "    \"Q_cooling_kWh_year\": float(daily_out[\"Q_cooling_kWh_day\"].sum()),\n",
    "    \"E_HP_total_kWh_year\": float(daily_out[\"E_HP_total_kWh_day\"].sum()),\n",
    "    \"peak_q_heating_kW\": float(df[\"q_heating_kW\"].max()),\n",
    "    \"peak_q_cooling_kW\": float(df[\"q_cooling_kW\"].max()),\n",
    "    \"peak_P_HP_total_kW\": float(df[\"P_HP_total_kW\"].max()),\n",
    "    \"COP_mean\": float(df[\"COP_t\"].mean()),\n",
    "    \"COP_min\": float(df[\"COP_t\"].min()),\n",
    "    \"COP_max\": float(df[\"COP_t\"].max()),\n",
